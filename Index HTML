                            className="px-2 py-1 bg-transparent hover:bg-slate-100 focus:bg-white rounded border-none text-xs text-slate-600 font-semibold outline-none cursor-pointer"
                          >
                            <option value="fixed">📌 Fixo</option>
                            <option value="one-time">🛍️ Pontual</option>
                          </select>
                        </td>
                        {/* Data */}
                        <td className="px-3 py-2 text-center">
                          <input
                            type="date"
                            value={exp.date}
                            onChange={(e) => handleSpreadsheetCellChange(exp.id, 'date', e.target.value)}
                            className="px-2 py-1 bg-transparent hover:bg-slate-100 focus:bg-white rounded border-none text-xs text-slate-600 outline-none"
                          />
                        </td>
                        {/* Valor */}
                        <td className="px-3 py-2 text-right">
                          <div className="flex items-center justify-end">
                            <span className="text-xs text-slate-400 mr-1">R$</span>
                            <input
                              type="number"
                              step="0.01"
                              value={exp.amount}
                              onChange={(e) => handleSpreadsheetCellChange(exp.id, 'amount', e.target.value)}
                              className="w-20 px-2 py-1 bg-transparent hover:bg-slate-100 focus:bg-white focus:ring-1 focus:ring-emerald-500 rounded border-none font-bold text-right text-slate-800 outline-none text-sm"
                            />
                          </div>
                        </td>
                        {/* Ação */}
                        <td className="px-3 py-2 text-center">
                          <button
                            onClick={() => handleDeleteExpense(exp.id)}
                            className="text-slate-400 hover:text-rose-600 p-1 rounded-lg hover:bg-rose-50 transition"
                            title="Remover linha"
                          >
                            🗑️
                          </button>
                        </td>
                      </tr>
                    ))
                  ) : (
                    <tr>
                      <td colSpan="6" className="px-4 py-12 text-center text-slate-400">
                        Nenhuma linha de despesa lançada para {formatMonthName(currentMonth)}. Use o botão de copiar contas do mês passado ou volte para a aba do Dashboard para criar novas!
                      </td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>

            {/* Totalizador da Planilha */}
            <div className="bg-slate-50 p-4 rounded-xl flex flex-col sm:flex-row justify-between items-center gap-4 text-sm">
              <span className="font-semibold text-slate-600">Linhas ativas na planilha: <strong className="text-slate-800">{activeMonthExpenses.length}</strong></span>
              <div className="flex gap-4 font-bold">
                <span className="text-blue-700">Total Fixo: R$ {totalFixed.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</span>
                <span className="text-amber-700">Total Pontual: R$ {totalOneTime.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</span>
                <span className="text-slate-800 border-l border-slate-300 pl-4">Soma Geral: R$ {totalExpenses.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</span>
              </div>
            </div>
          </section>
        )}

        {/* --- ABA 3: CENTRAL DE BACKUP E SEGURANÇA (O SEU SEGURO CONTRA FALHAS) --- */}
        {activeTab === 'backup' && (
          <section className="grid grid-cols-1 md:grid-cols-2 gap-8">
            
            {/* O que fazer se der problema */}
            <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-between">
              <div>
                <h3 className="font-bold text-lg text-rose-800 flex items-center gap-2">
                  <span>🛡️ Prevenção contra Perda de Dados</span>
                </h3>
                <p className="text-xs text-slate-500 mt-1">Saber como funciona a sua segurança evita qualquer dor de cabeça no futuro.</p>
                
                <div className="mt-4 space-y-4 text-xs text-slate-600 leading-relaxed">
                  <div className="p-3 bg-rose-50 rounded-lg border border-rose-100">
                    <p className="font-bold text-rose-900 mb-1">Como os dados são salvos?</p>
                    <p>Por padrão, todo o seu preenchimento de salários, metas e despesas fica salvo no armazenamento local (`localStorage`) do seu navegador. Isso significa que se você fechar e abrir a aba, suas informações continuam lá.</p>
                  </div>
                  <div className="p-3 bg-amber-50 rounded-lg border border-amber-100">
                    <p className="font-bold text-amber-900 mb-1">O que pode apagar suas informações?</p>
                    <ul className="list-disc pl-4 space-y-1 mt-1">
                      <li>Limpar os cookies, histórico ou dados do navegador.</li>
                      <li>Usar o navegador em modo "Aba Anônima".</li>
                      <li>Formatar o celular ou computador.</li>
                    </ul>
                  </div>
                  <div className="p-3 bg-emerald-50 rounded-lg border border-emerald-100">
                    <p className="font-bold text-emerald-900 mb-1">Como evitar perda total?</p>
                    <p>Crie o hábito de clicar em **"Baixar Backup Completo"** no final de cada mês. Guarde o arquivo `.json` gerado na sua nuvem (Google Drive, iCloud) ou envie para você mesmo por WhatsApp/e-mail. Caso algo deu errado, basta fazer o upload do arquivo para recuperar absolutamente tudo.</p>
                  </div>
                </div>
              </div>

              <div className="mt-6 text-center text-[10px] text-slate-400">
                Seu Painel de Controle usa criptografia padrão de exportação em JSON puro.
              </div>
            </div>

            {/* Painel de Ações de Backup */}
            <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-between space-y-6">
              <div>
                <h3 className="font-bold text-lg text-slate-800">💾 Gerenciamento de Arquivos de Backup</h3>
                <p className="text-xs text-slate-500">Exporte ou restaure suas finanças em menos de 10 segundos.</p>
              </div>

              {/* Botões Grandes de Ação */}
              <div className="space-y-4">
                {/* Exportar */}
                <div className="p-4 border border-slate-100 rounded-xl hover:border-slate-200 transition">
                  <h4 className="font-bold text-sm text-slate-800 mb-1">1. Salvar meu progresso atual</h4>
                  <p className="text-[11px] text-slate-400 mb-3">Faz o download do seu banco de dados atualizado com todos os meses integrados.</p>
                  <button
                    onClick={handleExportBackup}
                    className="w-full py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white font-bold rounded-xl text-xs shadow-sm hover:shadow transition duration-150 flex justify-center items-center gap-2"
                  >
                    📥 Baixar Backup Completo (.JSON)
                  </button>
                </div>

                {/* Importar */}
                <div className="p-4 border border-slate-100 rounded-xl hover:border-slate-200 transition">
                  <h4 className="font-bold text-sm text-slate-800 mb-1">2. Restaurar um backup antigo</h4>
                  <p className="text-[11px] text-slate-400 mb-3">Carrega o seu arquivo de backup (.json) no navegador para voltar a usar o painel instantaneamente.</p>
                  
                  <input
                    type="file"
                    ref={fileInputRef}
                    onChange={handleImportBackup}
                    accept=".json"
                    className="hidden"
                  />
                  
                  <button
                    onClick={() => fileInputRef.current.click()}
                    className="w-full py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 border border-slate-200 font-bold rounded-xl text-xs transition flex justify-center items-center gap-2"
                  >
                    📤 Fazer Upload de Backup (.JSON)
                  </button>
                </div>
              </div>

              {/* Status Técnico */}
              <div className="bg-slate-50 p-4 rounded-xl text-xs space-y-1.5">
                <div className="flex justify-between">
                  <span className="text-slate-400 font-medium">Histórico Total Registrado:</span>
                  <span className="font-bold text-slate-800">{expenses.length} despesas</span>
                </div>
                <div className="flex justify-between">
                  <span className="text-slate-400 font-medium">Orçamentos Ativos:</span>
                  <span className="font-bold text-slate-800">{Object.keys(monthlyBudgets).length} meses configurados</span>
                </div>
                <div className="flex justify-between">
                  <span className="text-slate-400 font-medium">Último Mês Focado:</span>
                  <span className="font-bold text-slate-800">{formatMonthName(currentMonth)}</span>
                </div>
              </div>

            </div>

          </section>
        )}

      </main>

      {/* Footer */}
      <footer className="bg-slate-800 text-slate-400 py-8 mt-12 border-t border-slate-700">
        <div className="max-w-7xl mx-auto px-4 text-center space-y-2">
          <p className="text-sm font-semibold text-slate-300">Organizador Financeiro Multi-mês do Red 🚀</p>
          <p className="text-xs">Seguro, Privado e Portável: Seus dados permanecem seguros no seu navegador e sob o seu controle.</p>
        </div>
      </footer>
    </div>
  );
}
