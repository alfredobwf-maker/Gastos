import React, { useState, useEffect, useRef } from 'react';

// Categorias padrão para as despesas
const DEFAULT_CATEGORIES = [
  { id: 'moradia', name: 'Moradia', icon: '🏠', color: 'bg-blue-100 text-blue-700 border-blue-200' },
  { id: 'alimentacao', name: 'Alimentação', icon: '🍔', color: 'bg-amber-100 text-amber-700 border-amber-200' },
  { id: 'transporte', name: 'Transporte', icon: '🚗', color: 'bg-indigo-100 text-indigo-700 border-indigo-200' },
  { id: 'lazer', name: 'Lazer & Viagens', icon: '🎉', color: 'bg-purple-100 text-purple-700 border-purple-200' },
  { id: 'saude', name: 'Saúde', icon: '❤️', color: 'bg-rose-100 text-rose-700 border-rose-200' },
  { id: 'educacao', name: 'Educação', icon: '📚', color: 'bg-emerald-100 text-emerald-700 border-emerald-200' },
  { id: 'outros', name: 'Outros', icon: '🏷️', color: 'bg-slate-100 text-slate-700 border-slate-200' }
];

// Gerador de ID robusto e compatível com ambientes restritos/sandboxed
const generateUUID = () => {
  try {
    if (typeof crypto !== 'undefined' && typeof crypto.randomUUID === 'function') {
      return crypto.randomUUID();
    }
  } catch (e) {}
  return Math.random().toString(36).substring(2, 15) + Date.now().toString(36);
};

export default function App() {
  // --- ESTADOS ---
  const [currentMonth, setCurrentMonth] = useState('2026-06'); // Formato "YYYY-MM"
  const [activeTab, setActiveTab] = useState('dashboard'); // 'dashboard' | 'spreadsheet' | 'backup'
  const fileInputRef = useRef(null);
  
  // Dicionário de orçamentos por mês: { "YYYY-MM": { income, savingsGoal } }
  const [monthlyBudgets, setMonthlyBudgets] = useState({
    '2026-06': { income: 5000, savingsGoal: 1000 }
  });

  const [expenses, setExpenses] = useState([
    // Dados de exemplo para o mês de Junho/2026
    { id: '1', description: 'Aluguel e Condomínio', amount: 1500, type: 'fixed', category: 'moradia', date: '2026-06-01' },
    { id: '2', description: 'Supermercado Mensal', amount: 650, type: 'fixed', category: 'alimentacao', date: '2026-06-02' },
    { id: '3', description: 'Combustível', amount: 300, type: 'one-time', category: 'transporte', date: '2026-06-05' },
    { id: '4', description: 'Jantar de Aniversário', amount: 180, type: 'one-time', category: 'lazer', date: '2026-06-08' },
    { id: '5', description: 'Farmácia', amount: 95, type: 'one-time', category: 'saude', date: '2026-06-10' },
    { id: '6', description: 'Curso Online de Tech', amount: 250, type: 'fixed', category: 'educacao', date: '2026-06-12' }
  ]);

  // Valores de fallback se o mês selecionado não possuir orçamento ainda
  const defaultIncome = 5000;
  const defaultSavingsGoal = 1000;

  // Orçamento ativo do mês selecionado
  const activeBudget = monthlyBudgets[currentMonth] || { income: defaultIncome, savingsGoal: defaultSavingsGoal };
  const income = activeBudget.income;
  const savingsGoal = activeBudget.savingsGoal;

  // Formulário de Nova Despesa
  const [newDesc, setNewDesc] = useState('');
  const [newAmount, setNewAmount] = useState('');
  const [newType, setNewType] = useState('fixed'); // fixed ou one-time
  const [newCategory, setNewCategory] = useState('moradia');
  const [newDate, setNewDate] = useState('2026-06-01');

  // Controles de edição de Salário e Meta
  const [isEditingIncome, setIsEditingIncome] = useState(false);
  const [tempIncome, setTempIncome] = useState(income);
  const [isEditingGoal, setIsEditingGoal] = useState(false);
  const [tempGoal, setTempGoal] = useState(savingsGoal);

  // Filtros de listagem
  const [searchTerm, setSearchTerm] = useState('');
  const [filterType, setFilterType] = useState('all'); // all, fixed, one-time
  const [filterCategory, setFilterCategory] = useState('all');

  // Notificações
  const [notification, setNotification] = useState(null);

  // --- SINCRONIZAÇÃO DE TEMPORÁRIOS QUANDO O MÊS MUDAR ---
  useEffect(() => {
    setTempIncome(income);
    setTempGoal(savingsGoal);
    // Atualiza o formulário para apontar para o primeiro dia do novo mês selecionado
    setNewDate(`${currentMonth}-01`);
  }, [currentMonth, monthlyBudgets]);

  // --- PERSISTÊNCIA LOCAL ---
  useEffect(() => {
    try {
      const savedBudgets = localStorage.getItem('red_finance_monthly_budgets_v2');
      const savedExpenses = localStorage.getItem('red_finance_expenses_v2');
      const savedCurrentMonth = localStorage.getItem('red_finance_current_month');

      if (savedBudgets) {
        setMonthlyBudgets(JSON.parse(savedBudgets));
      }
      if (savedExpenses) {
        setExpenses(JSON.parse(savedExpenses));
      }
      if (savedCurrentMonth) {
        setCurrentMonth(savedCurrentMonth);
      }
    } catch (e) {
      console.warn("LocalStorage inacessível.");
    }
  }, []);

  const saveData = (updatedBudgets, updatedExpenses, monthToSave = currentMonth) => {
    try {
      localStorage.setItem('red_finance_monthly_budgets_v2', JSON.stringify(updatedBudgets));
      localStorage.setItem('red_finance_expenses_v2', JSON.stringify(updatedExpenses));
      localStorage.setItem('red_finance_current_month', monthToSave);
    } catch (e) {
      // Falha silenciosa se estiver num iframe restrito
    }
  };

  const triggerNotification = (message, type = 'success') => {
    setNotification({ message, type });
    setTimeout(() => setNotification(null), 3000);
  };

  // --- NAVEGAÇÃO DE MESES ---
  const formatMonthName = (monthStr) => {
    const [year, month] = monthStr.split('-');
    const months = [
      'Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho',
      'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'
    ];
    return `${months[parseInt(month, 10) - 1]} de ${year}`;
  };

  const navigateMonth = (direction) => {
    const [year, month] = currentMonth.split('-').map(Number);
    let newYear = year;
    let newMonth = month + direction;

    if (newMonth > 12) {
      newMonth = 1;
      newYear += 1;
    } else if (newMonth < 1) {
      newMonth = 12;
      newYear -= 1;
    }

    const newMonthStr = `${newYear}-${String(newMonth).padStart(2, '0')}`;
    setCurrentMonth(newMonthStr);
    saveData(monthlyBudgets, expenses, newMonthStr);
  };

  const handleMonthPickerChange = (e) => {
    if (e.target.value) {
      setCurrentMonth(e.target.value);
      saveData(monthlyBudgets, expenses, e.target.value);
    }
  };

  // --- AÇÕES DO ORÇAMENTO (SALÁRIO E META) ---
  const handleSaveIncome = () => {
    const val = parseFloat(tempIncome);
    if (!isNaN(val) && val >= 0) {
      const updated = {
        ...monthlyBudgets,
        [currentMonth]: {
          ...activeBudget,
          income: val
        }
      };
      setMonthlyBudgets(updated);
      setIsEditingIncome(false);
      saveData(updated, expenses);
      triggerNotification("Renda atualizada para este mês!");
    }
  };

  const handleSaveGoal = () => {
    const val = parseFloat(tempGoal);
    if (!isNaN(val) && val >= 0) {
      const updated = {
        ...monthlyBudgets,
        [currentMonth]: {
          ...activeBudget,
          savingsGoal: val
        }
      };
      setMonthlyBudgets(updated);
      setIsEditingGoal(false);
      saveData(updated, expenses);
      triggerNotification("Meta de poupança atualizada para este mês!");
    }
  };

  // --- GESTÃO DE DESPESAS ---
  const handleAddExpense = (e) => {
    e.preventDefault();
    const amountNum = parseFloat(newAmount);
    if (!newDesc.trim() || isNaN(amountNum) || amountNum <= 0) {
      triggerNotification("Por favor, informe a descrição e um valor válido.", "error");
      return;
    }

    const newExpense = {
      id: generateUUID(),
      description: newDesc.trim(),
      amount: amountNum,
      type: newType,
      category: newCategory,
      date: newDate || `${currentMonth}-01`
    };

    const updated = [newExpense, ...expenses];
    setExpenses(updated);
    saveData(monthlyBudgets, updated);

    // Reset formulário básico
    setNewDesc('');
    setNewAmount('');
    triggerNotification("Gasto registrado!");
  };

  const handleDeleteExpense = (id) => {
    const updated = expenses.filter(exp => exp.id !== id);
    setExpenses(updated);
    saveData(monthlyBudgets, updated);
    triggerNotification("Item removido.", "info");
  };

  // Atualização direta na planilha
  const handleSpreadsheetCellChange = (id, field, value) => {
    const updatedExpenses = expenses.map(exp => {
      if (exp.id === id) {
        let parsedValue = value;
        if (field === 'amount') {
          parsedValue = parseFloat(value) || 0;
        }
        return { ...exp, [field]: parsedValue };
      }
      return exp;
    });
    setExpenses(updatedExpenses);
    saveData(monthlyBudgets, updatedExpenses);
  };

  // --- COPIAR CONTAS FIXAS DO MÊS ANTERIOR ---
  const handleImportPreviousFixed = () => {
    const [year, month] = currentMonth.split('-').map(Number);
    let prevYear = year;
    let prevMonth = month - 1;

    if (prevMonth < 1) {
      prevMonth = 12;
      prevYear -= 1;
    }

    const prevMonthStr = `${prevYear}-${String(prevMonth).padStart(2, '0')}`;
    const previousFixedExpenses = expenses.filter(
      exp => exp.date.substring(0, 7) === prevMonthStr && exp.type === 'fixed'
    );

    if (previousFixedExpenses.length === 0) {
      triggerNotification("Não encontramos despesas fixas no mês anterior para importar.", "error");
      return;
    }

    const importedExpenses = previousFixedExpenses.map(oldExp => {
      const day = oldExp.date.substring(8, 10);
      return {
        ...oldExp,
        id: generateUUID(),
        date: `${currentMonth}-${day}`
      };
    });

    const updated = [...importedExpenses, ...expenses];
    setExpenses(updated);
    saveData(monthlyBudgets, updated);
    triggerNotification(`${importedExpenses.length} despesas fixas replicadas para este mês com sucesso!`);
  };

  // --- CÁLCULOS DINÂMICOS DO MÊS ATIVO ---
  const activeMonthExpenses = expenses.filter(
    exp => exp.date.substring(0, 7) === currentMonth
  );

  const totalFixed = activeMonthExpenses
    .filter(exp => exp.type === 'fixed')
    .reduce((sum, exp) => sum + exp.amount, 0);

  const totalOneTime = activeMonthExpenses
    .filter(exp => exp.type === 'one-time')
    .reduce((sum, exp) => sum + exp.amount, 0);

  const totalExpenses = totalFixed + totalOneTime;
  const remainingBalance = income - totalExpenses;
  const savingsGoalPercentage = Math.min(Math.round((remainingBalance / (savingsGoal || 1)) * 100), 100);

  // Totais por Categorias (Apenas do Mês Selecionado)
  const categoryTotals = DEFAULT_CATEGORIES.map(cat => {
    const total = activeMonthExpenses
      .filter(exp => exp.category === cat.id)
      .reduce((sum, exp) => sum + exp.amount, 0);
    return { ...cat, total };
  }).filter(cat => cat.total > 0);

  // Distribuição 50/30/20 do mês selecionado
  const fixedPercentageOfIncome = income > 0 ? (totalFixed / income) * 100 : 0;
  const oneTimePercentageOfIncome = income > 0 ? (totalOneTime / income) * 100 : 0;
  const savingsPercentageOfIncome = income > 0 ? (remainingBalance / income) * 100 : 0;

  // Filtragem da lista exibida
  const filteredExpenses = activeMonthExpenses.filter(exp => {
    const matchesSearch = exp.description.toLowerCase().includes(searchTerm.toLowerCase());
    const matchesType = filterType === 'all' || exp.type === filterType;
    const matchesCategory = filterCategory === 'all' || exp.category === filterCategory;
    return matchesSearch && matchesType && matchesCategory;
  });

  // --- EXPORTAR E IMPORTAR SISTEMAS ---
  
  // 1. Exportar para planilha real (Excel / Google Planilhas via CSV)
  const handleExportCSV = () => {
    if (activeMonthExpenses.length === 0) {
      triggerNotification("Não há gastos cadastrados para exportar neste mês.", "error");
      return;
    }

    const headers = ['Data', 'Descricao', 'Categoria', 'Tipo', 'Valor (R$)'];
    const rows = activeMonthExpenses.map(exp => {
      const catName = DEFAULT_CATEGORIES.find(c => c.id === exp.category)?.name || 'Outros';
      const typeLabel = exp.type === 'fixed' ? 'Fixo' : 'Pontual';
      const formattedAmount = exp.amount.toFixed(2).replace('.', ','); // Formato monetário brasileiro
      return [exp.date, exp.description, catName, typeLabel, formattedAmount];
    });

    // BOM para o Excel ler caracteres acentuados corretamente em UTF-8
    const csvContent = "\uFEFF" + [headers.join(';'), ...rows.map(r => r.join(';'))].join('\n');
    const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.setAttribute("href", url);
    link.setAttribute("download", `financas_red_${currentMonth}.csv`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    triggerNotification("Planilha exportada com sucesso!");
  };

  // 2. Copiar tabela direta formatada em colunas (Para dar Ctrl+V no Google Sheets)
  const handleCopyToClipboardForSheets = () => {
    if (activeMonthExpenses.length === 0) {
      triggerNotification("Nenhum dado para copiar.", "error");
      return;
    }

    const headers = ['Data', 'Descrição', 'Categoria', 'Tipo', 'Valor (R$)'];
    const rows = activeMonthExpenses.map(exp => {
      const catName = DEFAULT_CATEGORIES.find(c => c.id === exp.category)?.name || 'Outros';
      const typeLabel = exp.type === 'fixed' ? 'Fixo' : 'Pontual';
      return [exp.date, exp.description, catName, typeLabel, exp.amount.toString().replace('.', ',')];
    });

    const tsvContent = [headers.join('\t'), ...rows.map(r => r.join('\t'))].join('\n');

    // Usando fallback seguro para iFrame
    const tempTextArea = document.createElement('textarea');
    tempTextArea.value = tsvContent;
    document.body.appendChild(tempTextArea);
    tempTextArea.select();
    try {
      document.execCommand('copy');
      triggerNotification("Tabela copiada! Agora abra o Excel ou Google Planilhas e aperte Ctrl+V.");
    } catch (err) {
      triggerNotification("Erro ao copiar tabela.", "error");
    }
    document.body.removeChild(tempTextArea);
  };

  // 3. Exportar arquivo de Backup Completo (JSON)
  const handleExportBackup = () => {
    const backupObj = {
      monthlyBudgets,
      expenses,
      backupDate: new Date().toISOString(),
      owner: "Red"
    };

    const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(backupObj, null, 2));
    const link = document.createElement("a");
    link.setAttribute("href", dataStr);
    link.setAttribute("download", `backup_financeiro_completo_red.json`);
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    triggerNotification("Backup gerado e salvo com sucesso!");
  };

  // 4. Importar arquivo de Backup Completo (JSON)
  const handleImportBackup = (e) => {
    const fileReader = new FileReader();
    const file = e.target.files[0];
    if (!file) return;

    fileReader.onload = (event) => {
      try {
        const parsed = JSON.parse(event.target.result);
        if (parsed.monthlyBudgets && parsed.expenses) {
          setMonthlyBudgets(parsed.monthlyBudgets);
          setExpenses(parsed.expenses);
          
          // Tenta pegar o último mês ativo do backup
          if (parsed.expenses.length > 0) {
            const sortedDates = [...parsed.expenses].sort((a, b) => b.date.localeCompare(a.date));
            const latestMonth = sortedDates[0].date.substring(0, 7);
            setCurrentMonth(latestMonth);
            saveData(parsed.monthlyBudgets, parsed.expenses, latestMonth);
          } else {
            saveData(parsed.monthlyBudgets, parsed.expenses, currentMonth);
          }

          triggerNotification("Backup restaurado e sincronizado!");
        } else {
          triggerNotification("Arquivo de backup inválido.", "error");
        }
      } catch (err) {
        triggerNotification("Erro ao processar o arquivo de backup.", "error");
      }
    };
    fileReader.readAsText(file);
    // Limpa o input file
    e.target.value = null;
  };

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans antialiased pb-12">
      
      {/* Notificação Flutuante */}
      {notification && (
        <div className={`fixed top-4 right-4 z-50 flex items-center gap-2 px-4 py-3 rounded-xl shadow-lg border transition-all duration-300 ${
          notification.type === 'error' ? 'bg-rose-50 border-rose-200 text-rose-800' :
          notification.type === 'info' ? 'bg-blue-50 border-blue-200 text-blue-800' :
          'bg-emerald-50 border-emerald-200 text-emerald-800'
        }`}>
          <span className="text-lg">
            {notification.type === 'error' ? '⚠️' : notification.type === 'info' ? 'ℹ️' : '✨'}
          </span>
          <span className="text-sm font-semibold">{notification.message}</span>
        </div>
      )}

      {/* Header com o Seletor de Meses e Seletor de Abas */}
      <header className="bg-gradient-to-r from-emerald-600 to-teal-700 text-white shadow-md">
        <div className="max-w-7xl mx-auto px-4 py-6 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
          <div>
            <span className="text-xs font-semibold tracking-wider uppercase opacity-80 bg-emerald-500/30 px-2.5 py-1 rounded">
              Planejamento Financeiro Expandido
            </span>
            <h1 className="text-3xl font-bold tracking-tight mt-1">Olá, Red! 👋</h1>
            <p className="text-emerald-100 text-sm mt-0.5">Navegue, planeje e faça cópias de segurança de suas finanças.</p>
          </div>

          {/* Navegador de Meses Interativo */}
          <div className="flex items-center gap-3 bg-emerald-800/40 p-3 rounded-2xl border border-emerald-500/20 backdrop-blur-md">
            <button
              onClick={() => navigateMonth(-1)}
              className="p-2 bg-emerald-700 hover:bg-emerald-600 rounded-lg text-white font-bold transition text-sm animate-pulse-once"
              title="Mês Anterior"
            >
              ◀
            </button>
            
            <div className="flex flex-col items-center px-2 min-w-[150px]">
              <span className="text-xs opacity-75 uppercase font-bold tracking-wider text-[10px]">Mês de Referência</span>
              <span className="text-base font-extrabold tracking-wide text-center">
                {formatMonthName(currentMonth)}
              </span>
              <input
                type="month"
                value={currentMonth}
                onChange={handleMonthPickerChange}
                className="mt-1 text-[10px] bg-emerald-900/60 text-emerald-100 border-none rounded px-1.5 py-0.5 focus:ring-1 focus:ring-emerald-400 cursor-pointer outline-none"
              />
            </div>

            <button
              onClick={() => navigateMonth(1)}
              className="p-2 bg-emerald-700 hover:bg-emerald-600 rounded-lg text-white font-bold transition text-sm"
              title="Próximo Mês"
            >
              ▶
            </button>
          </div>
        </div>

        {/* Menu de Abas */}
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 bg-emerald-900/20 border-t border-emerald-500/20">
          <div className="flex space-x-1 py-2">
            <button
              onClick={() => setActiveTab('dashboard')}
              className={`px-4 py-2 text-xs font-bold rounded-lg transition ${
                activeTab === 'dashboard'
                  ? 'bg-white text-emerald-800 shadow'
                  : 'text-emerald-100 hover:bg-emerald-800/30'
              }`}
            >
              📊 Painel Visual
            </button>
            <button
              onClick={() => setActiveTab('spreadsheet')}
              className={`px-4 py-2 text-xs font-bold rounded-lg transition ${
                activeTab === 'spreadsheet'
                  ? 'bg-white text-emerald-800 shadow'
                  : 'text-emerald-100 hover:bg-emerald-800/30'
              }`}
            >
              🟢 Planilha Rápida (Grid)
            </button>
            <button
              onClick={() => setActiveTab('backup')}
              className={`px-4 py-2 text-xs font-bold rounded-lg transition ${
                activeTab === 'backup'
                  ? 'bg-white text-emerald-800 shadow'
                  : 'text-emerald-100 hover:bg-emerald-800/30'
              }`}
            >
              💾 Backups & Segurança
            </button>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto px-4 py-8 sm:px-6 lg:px-8 space-y-8">
        
        {/* Painel de Resultados do Mês Ativo */}
        <section className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          
          <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-md transition-shadow">
            <div className="flex justify-between items-start">
              <div>
                <p className="text-xs font-bold uppercase tracking-wider text-slate-400">Renda do Mês</p>
                {isEditingIncome ? (
                  <div className="mt-2 flex items-center gap-2">
                    <span className="text-slate-500 font-semibold">R$</span>
                    <input
                      type="number"
                      value={tempIncome}
                      onChange={(e) => setTempIncome(e.target.value)}
                      className="w-24 px-2 py-1 border rounded text-lg font-bold focus:outline-emerald-500"
                      autoFocus
                    />
                  </div>
                ) : (
                  <h3 className="text-2xl font-black text-slate-800 mt-1">
                    R$ {income.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}
                  </h3>
                )}
              </div>
              <div className="p-3 bg-emerald-50 text-emerald-600 rounded-xl">
                💰
              </div>
            </div>
            <div className="mt-4 pt-3 border-t border-slate-100 flex justify-end">
              {isEditingIncome ? (
                <div className="flex gap-2">
                  <button onClick={() => setIsEditingIncome(false)} className="text-xs text-slate-500 hover:underline px-2 py-1">Cancelar</button>
                  <button onClick={handleSaveIncome} className="text-xs bg-emerald-600 text-white font-medium px-2.5 py-1 rounded hover:bg-emerald-700 transition">Salvar</button>
                </div>
              ) : (
                <button onClick={() => { setTempIncome(income); setIsEditingIncome(true); }} className="text-xs text-emerald-600 hover:text-emerald-700 font-semibold flex items-center gap-1">✏️ Ajustar Renda</button>
              )}
            </div>
          </div>

          <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-md transition-shadow">
            <div className="flex justify-between items-start">
              <div>
                <p className="text-xs font-bold uppercase tracking-wider text-slate-400">Gastos Fixos</p>
                <h3 className="text-2xl font-black text-slate-800 mt-1">
                  R$ {totalFixed.toLocaleString('pt-BR', { minimumFractionDigits: 2 })}
                </h3>
              </div>
              <div className="p-3 bg-blue-50 text-blue-600 rounded-xl">
                📌
              </div>
            </div>
            <div className="mt-4 pt-3 border-t border-slate-100">
              <div className="flex items-center justify-between text-xs text-slate-500">
                <span>Representa {income > 0 ? ((totalFixed / income) * 100).toFixed(1) : 0}% da renda</span>
              </div>
            </div>
          </div>

          <div className="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 flex flex-col justify-between hover:shadow-md transition-shadow">
            <div className="flex justify-between items-start">
              <div>
                <p className="text-xs font-bold uppercase tracking-wider text-slate-400">Gastos Pontuais</p>
